    }
    .nav-dot {
      width: 9px; height: 9px; border-radius: 50%;
      background: #25D366; position: relative; flex-shrink: 0;
    }
    .nav-dot::after {
      content: '';
      position: absolute; inset: -3px;
      border-radius: 50%; border: 2px solid #25D366;
      animation: pulse-ring 1.6s ease-out infinite;
